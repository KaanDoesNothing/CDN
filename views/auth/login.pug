extends ../layouts/main

block body
    .flex.justify-center.mt-10
        .card.w-80.bg-base-100.shadow-xl.m-1.text-primary-content
            .card-body
                h2.card-title Login
                div(id="error", class="hidden")
                    br
                    div.toast.toast-top.toast-center
                        div.alert.alert-warning
                            div
                                span=error
                form.form-control(action="/auth/login" method="post")
                    label.label
                        span.label-text Email
                    input.input.input-bordered.w-full.max-w-xs(type="text" name="email")
                    label.label
                        span.label-text Password
                    input.input.input-bordered.w-full.max-w-xs(type="password" name="password")
                    .card-actions.text-center.mt-2
                        button.btn.btn-ghost.btn-block(type="submit") Login